+            document.querySelectorAll(".test-dd-toggle-btn").forEach(btn => {
+                btn.addEventListener("click", (e) => {
+                    e.stopPropagation();
+                    toggleTestDD(e, btn.dataset.testId);
+                });
+            });
+        }
+
+        function toggleTestDD(e, id) {
+            e.stopPropagation();
+            const wasOpen = document.querySelector(`.dd-menu[data-owner="test-${id}"]`);
+            closeAllDropdowns();
+            if (wasOpen) return; // ikkinchi bosishda yopilsin
+
+            const btn = e.currentTarget;
+            const rect = btn.getBoundingClientRect();
+            const menu = document.createElement("div");
+            menu.className = "dd-menu";
+            menu.dataset.owner = `test-${id}`;
+            menu.style.position = "fixed";
+            menu.style.top = (rect.bottom + 6) + "px";
+            menu.style.right = (window.innerWidth - rect.right) + "px";
+            menu.innerHTML = `
+                <button class="dd-item" onclick="openEditTestModal('${id}')"><i class="fas fa-pen"></i> Tahrirlash</button>
+                <button class="dd-item red" onclick="deleteTest('${id}')"><i class="fas fa-trash"></i> O'chirish</button>
+            `;
+            document.body.appendChild(menu);
         }
 
